{
  "name": "gitlab-mcp-server",
  "version": "0.7.0",
  "private": true,
  "description": "MCP server exposing a self-hosted or hosted GitLab instance to LLM clients (Claude Desktop, Claude Code, etc.) over stdio. 21 tools across issues, MRs, time tracking, repository code, search, and CI logs.",
  "type": "module",
  "bin": {
    "gitlab-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
