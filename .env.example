# Personal access token with `api` scope. Required.
# Create one at  https://<your-gitlab-host>/-/user_settings/personal_access_tokens
# (e.g. https://gitlab.com/-/user_settings/personal_access_tokens for gitlab.com).
GITLAB_TOKEN=

# GitLab API base URL. Optional; defaults to https://gitlab.com/api/v4
# Examples:
#   - Hosted: https://gitlab.com/api/v4
#   - Self-hosted: https://gitlab.example.com/api/v4
# GITLAB_URL=https://gitlab.com/api/v4

# Comma-separated GitLab project IDs the server treats as "default" for any
# project-scoped aggregations a future version may add. Optional; defaults to []
# (no defaults). Find numeric IDs on a project's home page.
# DEFAULT_PROJECT_IDS=

# Comma-separated list of Work Item Status names that list_my_issues treats as
# "actionable" by default — tickets in any other status are hidden unless the
# caller asks for them. Optional; defaults to "To do,In progress" (GitLab's
# stock workflow status names since 18.x). Set to empty string to disable the
# default filter entirely.
# ACTIONABLE_STATUSES=To do,In progress

# Set to 1 / true / yes to enable write tools (comment_on_*, create_issue,
# update_*, log_time, delete_time). Disabled by default so a misrouted tool
# call cannot mutate GitLab state.
# GITLAB_ENABLE_WRITES=true
